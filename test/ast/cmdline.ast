Program
  StmtList
    CommentStmt " Comment <trailing = no>
    CommentStmt " Indented comment <trailing = no>
    CommentStmt " Comment with a "string" contained <trailing = no>
    CommentStmt "Comment that just looks like a string" <trailing = no>
    CommentStmt " Tab-indented comment with "string" <trailing = no>
    CommentStmt "" Comment, but with multiple (even) leaders <trailing = no>
    CommentStmt """ Comment, but with multiple (odd) leaders <trailing = no>
    EmptyStmt <>
    AssignStmt = <>
      Var a
        NULL
      ListExpr
        Literal "a"
        Literal "b"
    CommentStmt "inline comment <trailing = yes>
    AssignStmt = <>
      Var a
        NULL
      Literal 2
    CommentStmt "inline comment with no leading whitespace <trailing = yes>
