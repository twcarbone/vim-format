Program
  StmtList
    CommentStmt " Comment <lvwp = 0; trailing = no>
    CommentStmt " Indented comment <lvwp = 0; trailing = no>
    CommentStmt " Comment with a "string" contained <lvwp = 0; trailing = no>
    CommentStmt "Comment that just looks like a string" <lvwp = 0; trailing = no>
    CommentStmt " Tab-indented comment with "string" <lvwp = 0; trailing = no>
    CommentStmt "" Comment, but with multiple (even) leaders <lvwp = 0; trailing = no>
    CommentStmt """ Comment, but with multiple (odd) leaders <lvwp = 0; trailing = no>
    AssignStmt = <lvwp = 1>
      Var a
      ListExpr
        Literal "a"
        Literal "b"
    CommentStmt "inline comment <lvwp = 0; trailing = yes>
    AssignStmt = <lvwp = 0>
      Var a
